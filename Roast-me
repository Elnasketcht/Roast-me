<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<title>Roast Generator</title>
<style>
  body {
    font-family: Arial, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background-color: #f0f0f0;
    flex-direction: column;
  }
  #startButton {
    padding: 20px 40px;
    font-size: 32px;
    cursor: pointer;
    border: none;
    border-radius: 10px;
    background-color: #d32f2f;
    color: white;
    transition: transform 0.2s;
  }
  #startButton:hover {
    transform: scale(1.1);
  }
  #roast {
    margin-top: 50px;
    font-size: 24px;
    color: #d32f2f;
    max-width: 600px;
    text-align: center;
  }
</style>
</head>
<body>

<button id="startButton">Roast</button>
<p id="roast"></p>

